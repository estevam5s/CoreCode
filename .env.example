# ==================================================
# CORECODE ENVIRONMENT
# ==================================================

# ── GROQ (GRATUITO — https://console.groq.com) ───
GROQ_API_KEY=

# ── OpenAI ───────────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o

# ── Gemini ────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── Anthropic ─────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Codex / GitHub Models ─────────────────────────
GITHUB_TOKEN=

# ── Ollama (local, sem chave) ─────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5-coder:7b

# ── CoreCode defaults ─────────────────────────────
# Troque para: groq | openai | gemini | anthropic | ollama | mock
CORECODE_DEFAULT_PROVIDER=mock
CORECODE_DEFAULT_MODEL=
CORECODE_THEME=monochrome
