{
  "name": "corecode-vscode",
  "displayName": "CoreCode",
  "description": "CoreCode AI Chat — 348+ AI models inside VS Code. Groq (free), OpenAI, Claude, Gemini, DeepSeek, Grok, Mistral, Ollama and more. No API key needed to start.",
  "version": "0.2.1",
  "publisher": "corecodecli",
  "icon": "media/corecode-icon.png",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Other",
    "Themes"
  ],
  "keywords": [
    "corecode",
    "ai",
    "chat",
    "llm",
    "groq",
    "openai",
    "claude",
    "gemini",
    "deepseek",
    "grok",
    "mistral",
    "openrouter",
    "ollama",
    "terminal",
    "cli",
    "agent",
    "copilot",
    "coding assistant",
    "code review",
    "autocomplete",
    "ai assistant",
    "chatgpt",
    "free ai"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:corecode.start",
    "onCommand:corecode.openChat",
    "onCommand:corecode.startInWorkspaceRoot",
    "onCommand:corecode.openDocs",
    "onCommand:corecode.openSetupDocs",
    "onCommand:corecode.openWorkspaceProfile",
    "onCommand:corecode.openControlCenter",
    "onView:corecode.controlCenter"
  ],
  "main": "./src/extension.js",
  "files": [
    "LICENSE",
    "README.md",
    "media/**",
    "src/extension.js",
    "src/chat-panel.js",
    "src/models.js",
    "src/presentation.js",
    "src/state.js",
    "themes/**"
  ],
  "contributes": {
    "commands": [
      {
        "command": "corecode.openChat",
        "title": "CoreCode: Abrir Chat IA",
        "category": "CoreCode",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "corecode.start",
        "title": "CoreCode: Launch in Terminal",
        "category": "CoreCode",
        "icon": "$(terminal)"
      },
      {
        "command": "corecode.startInWorkspaceRoot",
        "title": "CoreCode: Launch in Workspace Root",
        "category": "CoreCode"
      },
      {
        "command": "corecode.openDocs",
        "title": "CoreCode: Open Repository",
        "category": "CoreCode"
      },
      {
        "command": "corecode.openSetupDocs",
        "title": "CoreCode: Open Setup Guide",
        "category": "CoreCode"
      },
      {
        "command": "corecode.openWorkspaceProfile",
        "title": "CoreCode: Open Workspace Profile",
        "category": "CoreCode"
      },
      {
        "command": "corecode.openControlCenter",
        "title": "CoreCode: Open Control Center",
        "category": "CoreCode"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "corecode",
          "title": "CoreCode",
          "icon": "media/corecode.svg"
        }
      ]
    },
    "views": {
      "corecode": [
        {
          "id": "corecode.controlCenter",
          "name": "Control Center",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "editor/title": [
        {
          "command": "corecode.openChat",
          "group": "navigation",
          "when": "true"
        }
      ]
    },
    "configuration": {
      "title": "CoreCode",
      "properties": {
        "corecode.launchCommand": {
          "type": "string",
          "default": "corecode",
          "description": "Command run in the integrated terminal when launching CoreCode."
        },
        "corecode.terminalName": {
          "type": "string",
          "default": "CoreCode",
          "description": "Integrated terminal tab name for CoreCode sessions."
        },
        "corecode.useOpenAIShim": {
          "type": "boolean",
          "default": false,
          "description": "Optionally set CLAUDE_CODE_USE_OPENAI=1 in launched CoreCode terminals."
        },
        "corecode.defaultModel": {
          "type": "string",
          "default": "groq/llama-3.3-70b-versatile",
          "description": "Default AI model for CoreCode Chat."
        }
      }
    },
    "themes": [
      {
        "label": "CoreCode Terminal Black",
        "uiTheme": "vs-dark",
        "path": "./themes/CoreCode-Terminal-Black.json"
      }
    ]
  },
  "scripts": {
    "test": "node --test ./src/*.test.js",
    "lint": "node -e \"for (const file of require('node:fs').readdirSync('./src')) { if (file.endsWith('.js') && !file.includes('chat') && !file.includes('models')) { require('node:child_process').execFileSync(process.execPath, ['--check', require('node:path').join('src', file)], { stdio: 'inherit' }); } }\"",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/estevam5s/CoreCode"
  },
  "license": "MIT"
}
